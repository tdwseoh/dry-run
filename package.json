{
  "name": "dry-run",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Dry Run — a solo rehearsal trainer for DECA roleplay events.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:llm": "node --env-file=.env scripts/check-llm.mjs",
    "test:judge": "node --env-file=.env --import tsx scripts/test-judge.ts"
  },
  "dependencies": {
    "@fontsource-variable/archivo": "^5.1.1",
    "@fontsource-variable/jetbrains-mono": "^5.1.1",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vercel/node": "^3.2.24",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
